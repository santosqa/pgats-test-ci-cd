{
  "name": "usados-de-qualidade",
  "version": "1.0.0",
  "description": "Site estático de vendas com testes automatizados e CI/CD",
  "main": "app.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest",
    "test:unit:ci": "mkdir -p reports && jest --coverage --json --outputFile=reports/unit-results.json --reporters=default --reporters=jest-junit",
    "test:functional": "npm run build:catalog && playwright test",
    "test:ci": "npm run test:unit:ci && npm run test:functional",
    "build:catalog": "python3 scripts/build_catalog.py",
    "serve": "python3 -m http.server 8000"
  },
  "keywords": [
    "ci-cd",
    "github-actions",
    "testing",
    "automation"
  ],
  "author": "Ricardo Santos",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0"
  }
}
